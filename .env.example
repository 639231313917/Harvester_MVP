# === SimilarWeb (через rapidapi) ===
SIMILARWEB_API_KEY=your_rapidapi_key_here
SIMILARWEB_HOST=similarweb12.p.rapidapi.com

# === Snov.io ===
# Берутся в кабинете Snov → Settings → API. Там это называется User Id + Secret.
SNOV_CLIENT_ID=your_snov_user_id
SNOV_CLIENT_SECRET=your_snov_secret

# === Пороги фильтрации ===
# Минимум посещений сайта в месяц (SimilarWeb). Всё что меньше — отсеивается.
MIN_MONTHLY_VISITS=100000

# Минимум валидных строк в ads.txt + app-ads.txt (суммарно).
# Игнорируются пустые строки и комментарии (начинающиеся с #).
MIN_ADS_TXT_LINES=5

# === Производительность ===
CONCURRENCY_LIMIT=30
REQUEST_TIMEOUT=15

# Отдельный лимит для API с платной квотой — они не любят высокий rps
API_CONCURRENCY_LIMIT=10
